{
  "entities": {
    "Lot": {
      "title": "Import Lot",
      "description": "Represents a specific batch of imported items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quantity": { "type": "number" },
        "remainingStock": { "type": "number" },
        "totalCost": { "type": "number" },
        "unitCost": { "type": "number" },
        "importDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "quantity", "remainingStock", "totalCost", "unitCost", "importDate"]
    },
    "Product": {
      "title": "Clothing Item",
      "description": "Represents a piece of clothing in the inventory.",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "material": { "type": "string" },
        "totalStock": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "location": { "type": "string" },
        "lots": { "type": "array", "items": { "$ref": "#/entities/Lot" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sku", "name", "totalStock", "sellingPrice"]
    },
    "Sale": {
      "title": "Sale Transaction",
      "description": "Records a sale transaction.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "lotId": { "type": "string" },
        "sku": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "totalPrice": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "location": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "quantity", "totalPrice", "paymentMethod", "timestamp"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory of products."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Historical sales records."
    }
  }
}
